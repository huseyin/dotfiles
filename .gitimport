- remote: https://github.com/omu/zoo
  files:
    - source: git-import/git-import
      target: bin

- remote: https://github.com/omu/debian
  files:
    - source: etc/zsh
      target: etc

    - source: etc/tmux/tmux/conf.d
      target: etc/tmux

    - source: etc/tmux/tmux/hooks
      target: etc/tmux

    - source: etc/tmux/tmux.conf
      target: etc/tmux

    - source: etc/mc
      target: etc

    - source: lib/scripts/base/font.sh
      target: lib/scripts/base

    - source: lib/scripts/base/operator.sh
      target: lib/scripts/base

    - source: lib/scripts/base/staff.sh
      target: lib/scripts/base

    - source: lib/scripts/base/timezone.sh
      target: lib/scripts/base

    - source: lib/scripts/development/debian.sh
      target: lib/scripts/development

    - source: lib/scripts/development/shell.sh
      target: lib/scripts/development
